---
const features = [
  {
    icon: '⚡',
    title: 'Native Performance',
    description: 'Compiles to Rust, then to a native binary. No interpreter, no VM, no garbage collector. Just raw performance.',
  },
  {
    icon: '🎯',
    title: 'Clean Syntax',
    description: 'Familiar syntax inspired by TypeScript and Python. Type inference, one-liner functions, string templates, and more.',
  },
  {
    icon: '🛡️',
    title: 'Safe by Default',
    description: 'Explicit error handling with error binding — no exceptions, no null surprises. Errors are values you handle, not catch.',
  },
  {
    icon: '🔀',
    title: 'Hybrid Concurrency',
    description: 'async for I/O, par for CPU-bound tasks. task/fire/await for fine-grained control. No colored functions.',
  },
  {
    icon: '📦',
    title: 'Rich Standard Library',
    description: 'Arrays, strings, math, file I/O, HTTP, JSON — all built-in. 37+ functions ready to use, no packages needed.',
  },
  {
    icon: '🧩',
    title: 'Full IDE Support',
    description: 'VS Code extension with LSP: autocompletion, go to definition, hover types, real-time diagnostics, and 60+ snippets.',
  },
];
---

<section id="features" class="py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Everything you need, nothing you don't
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Liva gives you modern language features that compile to efficient, safe Rust code.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((f) => (
        <div class="group p-6 rounded-2xl bg-surface-light/50 border border-white/5 hover:border-liva-500/20 hover:bg-surface-light transition-all duration-300">
          <div class="text-3xl mb-4">{f.icon}</div>
          <h3 class="text-lg font-semibold text-white mb-2">{f.title}</h3>
          <p class="text-gray-400 text-sm leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
