---
const features = [
  {
    icon: '⚡',
    title: 'Native Performance',
    description: 'Compiles to Rust, then to a native binary. No interpreter, no VM, no garbage collector. Inline rust { } blocks for full Rust ecosystem access.',
  },
  {
    icon: '🎯',
    title: 'Clean Syntax',
    description: 'Familiar syntax inspired by TypeScript and Python. Type inference, one-liner functions, string templates, and more.',
  },
  {
    icon: '🛡️',
    title: 'Safe by Default',
    description: 'Explicit error handling with error binding — no exceptions, no null surprises. Errors are values you handle, not catch.',
  },
  {
    icon: '🔀',
    title: 'Hybrid Concurrency',
    description: 'async for I/O, par for CPU-bound tasks. task/await for fine-grained control. Auto fire-and-forget inference. No colored functions.',
  },
  {
    icon: '📦',
    title: 'Rich Standard Library',
    description: 'Arrays, strings, math, file I/O, HTTP, JSON, logging, config — all built-in. 73+ functions ready to use, no packages needed.',
  },
  {
    icon: '🧩',
    title: 'Full IDE Support',
    description: 'VS Code extension with LSP: autocompletion, go to definition, hover types, real-time diagnostics, and 250+ snippets.',
  },
];
---

<section id="features" class="py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-base-content mb-4">
        Everything you need, nothing you don't
      </h2>
      <p class="text-base-content/60 text-lg max-w-2xl mx-auto">
        Liva gives you modern language features that compile to efficient, safe Rust code.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((f) => (
        <div class="card bg-base-200/50 border border-base-content/5 hover:border-primary/20 transition-all duration-300">
          <div class="card-body">
            <div class="text-3xl mb-2">{f.icon}</div>
            <h3 class="card-title text-base-content">{f.title}</h3>
            <p class="text-base-content/60 text-sm leading-relaxed">{f.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
