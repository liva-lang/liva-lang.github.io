---
---

<section class="relative pt-32 pb-20 md:pt-44 md:pb-32 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] rounded-full bg-primary/10 blur-[120px]"></div>
    <div class="absolute bottom-0 left-1/4 w-[400px] h-[400px] rounded-full bg-secondary/5 blur-[100px]"></div>
  </div>

  <div class="max-w-6xl mx-auto px-6">
    <!-- Top section: text left, code right -->
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Text content -->
      <div class="text-left">
        <!-- Badge -->
        <a
          href="https://github.com/liva-lang/livac/releases/latest"
          target="_blank"
          class="badge badge-outline badge-primary gap-2 px-4 py-3 mb-8 hover:bg-primary/10 transition-colors"
        >
          <span class="w-2 h-2 rounded-full bg-success animate-pulse"></span>
          v1.3.0 — Error Tracing & Auto Fire-and-Forget
        </a>

        <!-- Title -->
        <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight leading-[1.1] mb-6">
          <span class="text-base-content">Write </span>
          <span class="bg-gradient-to-r from-liva-400 to-purple-400 bg-clip-text text-transparent">clean code</span>
          <br />
          <span class="text-base-content">compile to </span>
          <span class="bg-gradient-to-r from-orange-400 to-amber-400 bg-clip-text text-transparent">Rust</span>
        </h1>

        <!-- Subtitle -->
        <p class="text-lg text-base-content/60 max-w-lg mb-10 leading-relaxed">
          Liva combines the simplicity of TypeScript with the safety and performance of Rust.
          No garbage collector. No runtime overhead. Just clean code that runs fast.
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#install" class="btn btn-primary btn-lg shadow-lg shadow-primary/25">
            Get Started
          </a>
          <a href="#code" class="btn btn-ghost btn-lg border border-base-content/10">
            See Examples
          </a>
        </div>
      </div>

      <!-- Right: Code preview -->
      <div class="mockup-code bg-base-200 shadow-2xl border border-base-content/5">
        <div class="px-1">
          <pre data-prefix=""><code><span class="text-base-content/40">// hello.liva</span></code></pre>
          <pre data-prefix="1"><code><span class="text-primary font-semibold">main</span><span class="text-base-content/60">()</span> <span class="text-base-content/60">{"{"}</span></code></pre>
          <pre data-prefix="2"><code>  <span class="text-info">let</span> <span class="text-base-content">name</span> = <span class="text-success">"World"</span></code></pre>
          <pre data-prefix="3"><code>  <span class="text-info">let</span> <span class="text-base-content">nums</span> = <span class="text-base-content/60">[</span><span class="text-warning">1</span>, <span class="text-warning">2</span>, <span class="text-warning">3</span>, <span class="text-warning">4</span>, <span class="text-warning">5</span><span class="text-base-content/60">]</span></code></pre>
          <pre data-prefix="4"><code></code></pre>
          <pre data-prefix="5"><code>  <span class="text-info">let</span> <span class="text-base-content">doubled</span> = <span class="text-base-content">nums</span>.<span class="text-primary">map</span><span class="text-base-content/60">(</span><span class="text-base-content">x</span> <span class="text-liva-400">=&gt;</span> <span class="text-base-content">x</span> * <span class="text-warning">2</span><span class="text-base-content/60">)</span></code></pre>
          <pre data-prefix="6"><code>  <span class="text-info">let</span> <span class="text-base-content">sum</span> = <span class="text-base-content">doubled</span>.<span class="text-primary">reduce</span><span class="text-base-content/60">((</span><span class="text-base-content">a</span>, <span class="text-base-content">b</span><span class="text-base-content/60">)</span> <span class="text-liva-400">=&gt;</span> <span class="text-base-content">a</span> + <span class="text-base-content">b</span>, <span class="text-warning">0</span><span class="text-base-content/60">)</span></code></pre>
          <pre data-prefix="7"><code></code></pre>
          <pre data-prefix="8"><code>  <span class="text-accent">print</span><span class="text-base-content/60">(</span><span class="text-success">$"Hello, {"{"}</span><span class="text-base-content">name</span><span class="text-success">{"}"}! Sum: {"{"}</span><span class="text-base-content">sum</span><span class="text-success">{"}"}"</span><span class="text-base-content/60">)</span></code></pre>
          <pre data-prefix="9"><code><span class="text-base-content/60">{"}"}</span></code></pre>
        </div>
      </div>
    </div>

    <!-- Bottom: stats/highlights -->
    <div class="mt-16 grid grid-cols-3 gap-4">
      <div class="bg-base-200/50 rounded-box border border-base-content/5 p-5 text-center">
        <div class="text-xs text-base-content/40 mb-1">Compiles to</div>
        <div class="text-xl font-bold text-primary">Rust</div>
        <div class="text-xs text-base-content/40 mt-1">Native binary</div>
      </div>
      <div class="bg-base-200/50 rounded-box border border-base-content/5 p-5 text-center">
        <div class="text-xs text-base-content/40 mb-1">Runtime</div>
        <div class="text-xl font-bold text-success">Zero</div>
        <div class="text-xs text-base-content/40 mt-1">No GC overhead</div>
      </div>
      <div class="bg-base-200/50 rounded-box border border-base-content/5 p-5 text-center">
        <div class="text-xs text-base-content/40 mb-1">Platforms</div>
        <div class="text-xl font-bold text-warning">3</div>
        <div class="text-xs text-base-content/40 mt-1">Linux, macOS, Windows</div>
      </div>
    </div>
  </div>
</section>
