---
const tabs = [
  {
    id: 'debian',
    label: 'Ubuntu / Debian',
    icon: '🐧',
    commands: [
      'curl -LO https://github.com/liva-lang/livac/releases/latest/download/livac_amd64.deb',
      'sudo dpkg -i livac_amd64.deb',
      'livac --version',
    ],
  },
  {
    id: 'mac',
    label: 'macOS',
    icon: '🍎',
    commands: [
      '# Apple Silicon (M1/M2/M3/M4)',
      'curl -L https://github.com/liva-lang/livac/releases/latest/download/livac-darwin-arm64.tar.gz | tar xz',
      'sudo mv livac /usr/local/bin/',
      'livac --version',
    ],
  },
  {
    id: 'source',
    label: 'From Source',
    icon: '🔧',
    commands: [
      'git clone https://github.com/liva-lang/livac.git',
      'cd livac',
      'cargo build --release',
      'cargo install --path .',
      'livac --version',
    ],
  },
];
---

<section id="install" class="py-24 md:py-32 bg-base-200/30">
  <div class="max-w-4xl mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-base-content mb-4">
        Get started in seconds
      </h2>
      <p class="text-base-content/60 text-lg">
        Pre-built binaries for Linux, macOS, and Windows. Or build from source.
      </p>
    </div>

    <!-- Install methods -->
    {tabs.map((tab) => (
      <div class="mb-6">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-lg">{tab.icon}</span>
          <h3 class="text-base-content font-semibold">{tab.label}</h3>
        </div>
        <div class="mockup-code bg-base-200 border border-base-content/5">
          {tab.commands.map(cmd =>
            cmd.startsWith('#')
              ? <pre data-prefix=""><code class="text-base-content/40">{cmd}</code></pre>
              : <pre data-prefix="$"><code>{cmd}</code></pre>
          )}
        </div>
      </div>
    ))}

    <!-- Quick start after install -->
    <div class="mt-12 text-center">
      <p class="text-base-content/60 mb-4">Then write your first program:</p>
      <div class="max-w-md mx-auto mockup-code bg-base-200 border border-base-content/5">
        <pre data-prefix=""><code class="text-base-content/40"># hello.liva</code></pre>
        <pre data-prefix=" "><code>main() =&gt; print("Hello, Liva!")</code></pre>
        <pre data-prefix="$"><code>livac hello.liva --run</code></pre>
        <pre data-prefix="" class="text-success"><code>Hello, Liva!</code></pre>
      </div>
    </div>

    <!-- Links -->
    <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="https://github.com/liva-lang/livac/releases/latest"
        target="_blank"
        class="btn btn-primary shadow-lg shadow-primary/25"
      >
        Download Latest Release
      </a>
      <a
        href="https://github.com/liva-lang/livac/blob/main/docs/QUICK_REFERENCE.md"
        target="_blank"
        class="btn btn-ghost border border-base-content/10"
      >
        Read the Docs
      </a>
    </div>
  </div>
</section>
